{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "site": "saebom-studyhall",
    "public": "site",
    "ignore": ["**/.*"],
    "headers": [
      {
        "source": "**/*.@(jpg|png|ico|webp)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=604800" }]
      },
      {
        "source": "/index.html",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "studyhall",
      "runtime": "nodejs22",
      "ignore": [
        "node_modules",
        ".git",
        "*.log"
      ]
    }
  ]
}
