{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "site": "saebom-studyhall",
    "public": "site",
    "ignore": ["**/.*"],
    "headers": [
      {
        "source": "**/*.@(jpg|jpeg|png|ico|webp|svg)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=604800" }]
      },
      {
        "source": "**/*.@(html|css|js)",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }]
      },
      {
        "source": "/",
        "headers": [{ "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }]
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "studyhall",
      "runtime": "nodejs22",
      "ignore": [
        "node_modules",
        ".git",
        "*.log"
      ]
    }
  ]
}
