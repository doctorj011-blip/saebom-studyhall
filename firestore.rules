rules_version = '2';

// ══════════════════════════════════════════════════════════════════════════
//  ⚠️  이 파일이 Firestore 보안 규칙의 "원본"(SINGLE SOURCE OF TRUTH)입니다.
//      2026-07-14 부로 Firebase 콘솔 규칙은 이 파일로 교체되어 관리됩니다.
//
//   · 규칙 변경은 반드시 "이 파일"을 고친 뒤 배포:
//         firebase deploy --only firestore:rules      (또는  scripts/deploy-rules.sh)
//   · Firebase 콘솔에서 직접 수정하지 마세요 — 다음 배포 때 이 파일로 덮어써집니다.
//   · 변경할 때마다 아래 [배포 이력]에 날짜·요약을 남겨 주세요(무엇이 바뀌었는지 추적).
//
//   [배포 이력]
//   - 2026-07-14  통합본을 파일로 이관 + 냉방 컬렉션 3개 추가(ac_config·ac_commands·ac_state)
//   - 2026-07-16  pendingSeats 추가 — 자리변경 예약(학생앱 미래 적용일)이 캐치올에 막혀
//                 permission-denied로 조용히 죽어 있던 것을 수정
//   - 2026-07-17  handover_notes 추가 — 조교 서면 인수인계 메모(관리자앱 📝 인수인계 탭)
//   - 2026-07-23  usage_logs 추가 — 학생앱 사용기록(관리앱 📊 사용기록 탭). create/read/delete만
//                 허용하고 update는 차단(기록 위조 방지)
// ══════════════════════════════════════════════════════════════════════════

// 새봄 면학관 Firestore 보안 규칙 (2026-07-10 통합본)
// 앱이 쓰는 컬렉션만 허용하고 그 외는 전부 차단합니다.
// ★ 2026-07-10 11:47 게시본에서 빠졌던 세션 엔진(attendance_sessions/current_sessions)과
//   퇴원 보관함(withdrawn_students)을 복원하고, 캐치올 안에 갇혀 있던
//   상담예약(consultations)·학생관리앱(sm_) 규칙을 밖으로 꺼낸 통합본입니다.

service cloud.firestore {
  match /databases/{database}/documents {

    // 학생·스케줄 (관리자앱 저장, 학생앱 자리선택, 학부모앱 조회)
    match /students/{id}       { allow read, write: if true; }
    match /schedules/{id}      { allow read, write: if true; }
    match /schedule_base/{id}  { allow read, write: if true; }
    match /daily_reports/{id}  { allow read, write: if true; }

    // 예약된 자리변경 (학생앱이 미래 적용일에 고른 자리 / 관리자앱이 새벽 2시에 커밋)
    // 문서 ID = 대상 좌석번호. 예약 문서 자체가 좌석 선점 잠금 역할을 한다.
    match /pendingSeats/{seat} { allow read, write: if true; }

    // 입퇴실 기록(감사용): 형식 검증 (type은 in/out만, 이름 30자 이내)
    match /checkin_logs/{id} {
      allow read, delete: if true;
      allow create, update: if request.resource.data.type in ['in', 'out']
        && request.resource.data.studentName is string
        && request.resource.data.studentName.size() <= 30
        && request.resource.data.date is string
        && (!('away' in request.resource.data) || request.resource.data.away is bool);
    }

    // ── 시간기록 세션 엔진 (2026-07-10): 입실~퇴실 = 문서 1건 ──
    match /attendance_sessions/{id} {
      allow read, delete: if true;
      allow create, update: if request.resource.data.studentName is string
        && request.resource.data.studentName.size() <= 30
        && request.resource.data.inTs is int
        && request.resource.data.status in ['open', 'closed'];
    }
    // 열린 세션 포인터 (입실 중 = 문서 존재, 퇴실 = 삭제)
    match /current_sessions/{name} {
      allow read, delete: if true;
      allow create, update: if request.resource.data.studentName is string
        && request.resource.data.studentName.size() <= 30
        && request.resource.data.inTs is int;
    }

    // 퇴원생 보관함 (soft delete — 복구/영구삭제/90일 자동정리)
    match /withdrawn_students/{id} { allow read, write: if true; }

    // 스터디룸 신청
    match /studyroom_requests/{id} { allow read, write: if true; }

    // 스케줄 변경 벌점: 학생앱이 기록, 관리자앱이 취소/복구, 세 앱 모두 조회
    match /penalties/{id} {
      allow read: if true;
      allow create, update: if request.resource.data.keys().hasAll(['name', 'seatKey', 'date', 'periods'])
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 30
        && request.resource.data.seatKey is string
        && request.resource.data.date is string
        && request.resource.data.periods is map;
      allow delete: if false;
    }

    // 상점: 관리자가 수동 부여 (사용시간 탭 상점현황). 벌점과 동일한 개방 정책.
    match /merits/{id} {
      allow read: if true;
      allow create, update: if request.resource.data.keys().hasAll(['name', 'seatKey', 'date', 'points'])
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 30
        && request.resource.data.seatKey is string
        && request.resource.data.date is string
        && request.resource.data.points is int
        && request.resource.data.points > 0;
      allow delete: if false;
    }

    // 좌석 상태: 태블릿 디텍터가 쓰고 대시보드가 읽음
    match /seat_status/{seat} { allow read, write: if true; }

    // 검수 피드백: 대시보드가 사람 판정 결과 기록
    match /feedback_events/{id} { allow read, write: if true; }

    // SEE EYES 동의: 학생앱이 본인 동의 기록·철회, 대시보드/관리자가 조회
    match /see_eyes_consents/{seat} { allow read, write: if true; }

    // 사용기록: 학생앱이 남기는 앱 사용 로그(로그인·탭 열람 등).
    // 남기기(create)와 조회·정리(read/delete)만 허용하고, 한 번 쓴 기록의 수정(update)은 막는다.
    match /usage_logs/{id} {
      allow read, delete: if true;
      allow create: if request.resource.data.name is string
        && request.resource.data.name.size() <= 30
        && request.resource.data.event is string
        && request.resource.data.event.size() <= 40
        && request.resource.data.date is string;
      allow update: if false;
    }

    // 공지사항: list 문서 하나만 쓰기 허용
    match /notices/{id} {
      allow read: if true;
      allow write: if id == 'list';
    }

    // 조교 인수인계 메모 (문서 ID = {운영일}_{근무조}). 삭제는 막는다 —
    // 인수인계 기록이 사라지면 "안 남겼다/못 봤다"를 확인할 방법이 없어진다.
    match /handover_notes/{id} {
      allow read: if true;
      allow create, update: if request.resource.data.keys().hasAll(['date', 'shift', 'author', 'body'])
        && request.resource.data.date is string
        && request.resource.data.shift in ['morning', 'afternoon', 'night']
        && request.resource.data.author is string
        && request.resource.data.author.size() <= 20
        && request.resource.data.body is string
        && request.resource.data.body.size() <= 3000;
      allow delete: if false;
    }

    // 설정: 앱이 실제로 쓰는 문서만 허용
    // admin_auth = 관리자 기기 등록 마스터 비밀번호(salt+PBKDF2 해시). read는 검증에 필요.
    // vacation_mode = 방학 시간표(평일도 1~11교시). 3개 앱이 read, 관리자앱 설정 탭이 write.
    match /settings/{id} {
      allow read: if true;
      allow write: if id in ['solapi', 'schedule_edit', 'billing', 'admin_auth', 'seatSelection', 'vacation_mode'];
    }

    // 문자 발송 로그
    match /sms_logs/{id} { allow read, write: if true; }

    // 플래너 (사진 메타·선생님 코멘트)
    match /planners/{id}         { allow read, write: if true; }
    match /planner_comments/{id} { allow read, write: if true; }

    // 플래너 AI 검사 — 관리앱이 요청 생성(create만), 결과는 서버(Cloud Function)만 쓴다
    match /planner_ai_requests/{id} { allow read, create: if true; }
    // 결과는 서버가 쓰되, 요약 문장이 틀렸을 때 관리앱에서 고칠 수 있게 summary만 예외로 연다
    // (다시 검사는 API 재호출이라 비용이 든다). quality·stats·comment는 여전히 서버 전용.
    match /planner_ai_reviews/{id}  {
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['summary', 'summaryEditedAt'])
                    && request.resource.data.summary is string
                    && request.resource.data.summary.size() <= 1000;
    }

    // 자동문 원격 명령: current 문서만, action=open, 30초 이내
    match /door_commands/{id} {
      allow read: if true;
      allow write: if id == 'current'
        && request.resource.data.action == 'open'
        && request.resource.data.seconds is number
        && request.resource.data.seconds <= 30;
    }

    // ── 냉방(에어컨) 제어 — 입퇴실 자동 + 대시보드 수동 제어 ──
    // 로그인 없는 정적 앱이라 기존 컬렉션과 동일하게 개방. LG 통신·PAT는 서버(Cloud Function)만.
    // ac_config: 대시보드가 설정·zone(열람실/스터디룸) 매핑을 읽고 씀
    match /ac_config/{id} { allow read, write: if true; }
    // ac_commands: 대시보드가 수동 명령 생성(전원·온도·모드·풍량·검색). 실행 후 done/error 기록은 서버(Admin SDK)가 규칙 우회.
    match /ac_commands/{id} { allow read, create: if true; }
    // ac_state: 대시보드는 읽기만. 쓰기는 서버(Cloud Function, Admin SDK)만.
    match /ac_state/{id} { allow read: if true; }

    // 상담예약: 예약 등록·조회 허용
    match /consultations/{docId} {
      allow read, create, update, delete: if true;
    }

    // 학생관리앱: sm_ 접두사 컬렉션 (프로토타입 단계: 로그인 필요)
    match /{coll}/{docId} {
      allow read, write: if coll.matches('sm_.*') && request.auth != null;
    }

    // 수납관리: 월별 이용료 납부 기록
    match /payments/{paymentId} {
      allow read, delete: if true;
      allow create, update: if request.resource.data.keys().hasAll(['ym','key','amount'])
        && request.resource.data.amount is int
        && request.resource.data.amount > 0;
    }

    // 인건비 관리 (급여·주민번호): 원장 계정만 접근
    match /pay_employees/{docId} {
      allow read, write: if request.auth != null
        && request.auth.token.email == 'doctorj011@gmail.com';
    }
    match /pay_months/{docId} {
      allow read, write: if request.auth != null
        && request.auth.token.email == 'doctorj011@gmail.com';
    }

    // 그 외 모든 컬렉션은 읽기·쓰기 전부 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
